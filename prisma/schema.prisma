generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Household {
  id             Int             @id @default(autoincrement())
  name           String
  createdAt      DateTime        @default(now())
  soundEnabled        Boolean         @default(true)
  custodyModeEnabled  Boolean         @default(false)
  users          User[]
  people         Person[]
  tasks          Task[]
  projects       Project[]
  notes          Note[]
  recurringTasks RecurringTask[]
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  name        String?
  role        String    @default("member")  // "admin" | "member"
  timezone    String    @default("America/Los_Angeles")
  custodyMode String?   // "with_kids" | "without_kids" | null
  householdId Int
  household   Household @relation(fields: [householdId], references: [id])
  createdAt   DateTime  @default(now())
}

model Project {
  id             Int             @id @default(autoincrement())
  name           String
  description    String?
  status         String          @default("active")
  householdId    Int
  household      Household       @relation(fields: [householdId], references: [id])
  createdAt      DateTime        @default(now())
  tasks          Task[]
  notes          Note[]
  recurringTasks RecurringTask[]
}

model Note {
  id          Int          @id @default(autoincrement())
  title       String
  body        String?
  tags        String?      // comma-separated, normalized to lowercase
  householdId Int
  household   Household    @relation(fields: [householdId], references: [id])
  projectId   Int?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Attachment {
  id           Int      @id @default(autoincrement())
  filename     String   // UUID-based name, used as serve-route key
  originalName String
  mimeType     String
  size         Int
  blobUrl      String?  // Vercel Blob URL; null for legacy local files
  noteId       Int
  note         Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model Person {
  id             Int             @id @default(autoincrement())
  name           String
  email          String?         @unique
  streakCount    Int             @default(0)
  lastStreakDate DateTime?
  isKid          Boolean         @default(false)
  householdId    Int
  household      Household       @relation(fields: [householdId], references: [id])
  createdAt      DateTime        @default(now())
  tasks          Task[]
  recurringTasks RecurringTask[]
}

model RecurringTask {
  id                    Int       @id @default(autoincrement())
  title                 String
  notes                 String?
  time                  String?   // "HH:MM" 24-hour, optional
  intervalValue         Int
  intervalUnit          String    // "day" | "week" | "month" | "year" | "weekday"
  nextDue               DateTime
  lastCompleted         DateTime?
  reminderMinutesBefore Int?
  notifiedAt            DateTime?
  streak                Int       @default(0)
  custodyModes          String?   // null = always show; "with_kids" | "without_kids" = mode-gated
  lastActionAt          DateTime?
  householdId           Int
  household             Household @relation(fields: [householdId], references: [id])
  assigneeId            Int?
  assignee              Person?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  projectId             Int?
  project               Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt             DateTime  @default(now())
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userEmail String
  createdAt DateTime @default(now())
}

enum TaskCategory {
  HOME
  KIDS
  ERRANDS
  ADMIN
  HEALTH
  PERSONAL
}

model Task {
  id                    Int            @id @default(autoincrement())
  title                 String
  notes                 String?
  dueDate               DateTime?
  time                  String?        // "HH:MM" 24-hour, optional
  priority              String         @default("medium")
  category              TaskCategory?
  completed             Boolean        @default(false)
  reminderMinutesBefore Int?
  notifiedAt            DateTime?
  householdId           Int
  household             Household      @relation(fields: [householdId], references: [id])
  createdAt             DateTime       @default(now())
  completedAt           DateTime?
  assigneeId            Int?
  assignee              Person?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  projectId             Int?
  project               Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
}
