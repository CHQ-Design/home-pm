generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  notes       String?
  dueDate     DateTime?
  priority    String    @default("medium")
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
}
