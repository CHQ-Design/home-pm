generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id             Int             @id @default(autoincrement())
  name           String
  description    String?
  status         String          @default("active")
  createdAt      DateTime        @default(now())
  tasks          Task[]
  notes          Note[]
  recurringTasks RecurringTask[]
}

model Note {
  id          Int          @id @default(autoincrement())
  title       String
  body        String?
  tags        String?      // comma-separated, normalized to lowercase
  projectId   Int?
  project     Project?     @relation(fields: [projectId], references: [id])
  attachments Attachment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Attachment {
  id           Int      @id @default(autoincrement())
  filename     String   // UUID-based name on disk
  originalName String
  mimeType     String
  size         Int
  noteId       Int
  note         Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model Person {
  id             Int             @id @default(autoincrement())
  name           String
  email          String?         @unique
  streakCount    Int             @default(0)
  lastStreakDate DateTime?
  createdAt      DateTime        @default(now())
  tasks          Task[]
  recurringTasks RecurringTask[]
}

model RecurringTask {
  id                   Int       @id @default(autoincrement())
  title                String
  notes                String?
  time                 String?   // "HH:MM" 24-hour, optional
  intervalValue        Int
  intervalUnit         String    // "day" | "week" | "month" | "year" | "weekday"
  nextDue              DateTime
  lastCompleted        DateTime?
  reminderMinutesBefore Int?
  notifiedAt           DateTime?
  assigneeId           Int?
  assignee             Person?   @relation(fields: [assigneeId], references: [id])
  projectId            Int?
  project              Project?  @relation(fields: [projectId], references: [id])
  createdAt            DateTime  @default(now())
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userEmail String
  createdAt DateTime @default(now())
}

model Task {
  id                    Int       @id @default(autoincrement())
  title                 String
  notes                 String?
  dueDate               DateTime?
  time                  String?   // "HH:MM" 24-hour, optional
  priority              String    @default("medium")
  completed             Boolean   @default(false)
  reminderMinutesBefore Int?
  notifiedAt            DateTime?
  createdAt             DateTime  @default(now())
  completedAt           DateTime?
  assigneeId            Int?
  assignee              Person?   @relation(fields: [assigneeId], references: [id])
  projectId             Int?
  project               Project?  @relation(fields: [projectId], references: [id])
}
